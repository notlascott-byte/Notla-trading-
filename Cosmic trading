              <div style={{fontFamily:"Cinzel",fontSize:9,color:ACC,letterSpacing:3,marginBottom:14}}>PLANETARY INFLUENCE</div>
              {[
                {name:"Mercury ☿",rx:mercuryRx,note:mercuryRx?"RETROGRADE — fakeouts, reversals, avoid new entries":"Direct — clear signals, good for trading"},
                {name:"Venus ♀",rx:false,note:"Direct — gold & forex markets flow well"},
                {name:"Mars ♂",rx:false,note:"Direct — strong momentum, breakouts reliable"},
                {name:"Jupiter ♃",rx:false,note:"Direct — expansion energy, bull markets favored"},
                {name:"Saturn ♄",rx:false,note:"Direct — clear structure, disciplined trends"},
              ].map(p=>(
                <div key={p.name} style={{background:BG,border:`1px solid ${p.rx?RED+"33":BRD}`,borderRadius:7,padding:"10px 12px",marginBottom:7,display:"flex",justifyContent:"space-between",alignItems:"center",gap:8}}>
                  <div>
                    <div style={{fontFamily:"Cinzel",fontSize:11,color:p.rx?RED:ACC,marginBottom:3}}>{p.name}</div>
                    <div style={{fontSize:10,color:MUT}}>{p.note}</div>
                  </div>
                  <Pill label={p.rx?"Rx ℞":"DIRECT"} color={p.rx?RED:GRN}/>
                </div>
              ))}
            </Card>

            {/* Cosmic Score Full Width */}
            <Card style={{gridColumn:"1/-1"}}>
              <div style={{fontFamily:"Cinzel",fontSize:9,color:ACC,letterSpacing:3,marginBottom:16}}>TODAY'S COSMIC TRADING SCORE</div>
              <div style={{display:"flex",gap:20,alignItems:"center",marginBottom:16,flexWrap:"wrap"}}>
                <div style={{textAlign:"center"}}>
                  <div style={{fontFamily:"Cinzel",fontSize:60,fontWeight:900,color:cosmicScore>=70?GRN:cosmicScore>=50?GLD:RED,lineHeight:1}}>{cosmicScore}</div>
                  <div style={{fontSize:9,color:MUT}}>out of 100</div>
                </div>
                <div style={{flex:1,minWidth:200}}>
                  <div style={{height:7,background:BRD,borderRadius:4,marginBottom:8}}>
                    <div style={{height:"100%",width:`${cosmicScore}%`,background:`linear-gradient(90deg,${cosmicScore>=70?GRN:cosmicScore>=50?GLD:RED}66,${cosmicScore>=70?GRN:cosmicScore>=50?GLD:RED})`,borderRadius:4,boxShadow:`0 0 10px ${GRN}33`,transition:"width 1s ease"}}/>
                  </div>
                  <div style={{fontFamily:"Cinzel",fontSize:13,color:cosmicScore>=70?GRN:cosmicScore>=50?GLD:RED}}>
                    {cosmicScore>=80?"HIGHLY FAVORABLE — Trade with full confidence":cosmicScore>=60?"FAVORABLE — Normal position size":cosmicScore>=40?"NEUTRAL — Be selective, reduce size":"UNFAVORABLE — Skip today or very small size only"}
                  </div>
                </div>
              </div>
              <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(160px,1fr))",gap:8}}>
                {[
                  {l:"Moon Phase",pass:moon.favorable,note:moon.name},
                  {l:"Zodiac Season",pass:zodiac.bull,note:zodiac.name+(zodiac.bull?" bullish":" bearish")},
                  {l:"Mercury",pass:!mercuryRx,note:mercuryRx?"RETROGRADE ⚠":"Direct ✓"},
                  {l:"Numerology",pass:num.fav,note:`${num.num} — ${num.fav?"Favorable":"Challenging"}`},
                  {l:"Session Active",pass:session.vol!=="LOW",note:session.name},
                ].map(f=>(
                  <div key={f.l} style={{background:BG,border:`1px solid ${f.pass?GRN:RED}18`,borderRadius:7,padding:"9px 11px"}}>
                    <div style={{display:"flex",gap:6,alignItems:"center",marginBottom:3}}>
                      <span style={{color:f.pass?GRN:RED,fontSize:11}}>{f.pass?"✦":"○"}</span>
                      <span style={{fontFamily:"Cinzel",fontSize:9,color:f.pass?"#e2e0ff":MUT}}>{f.l}</span>
                    </div>
                    <div style={{fontSize:9,color:MUT}}>{f.note}</div>
                  </div>
                ))}
              </div>
            </Card>
          </div>
        )}

        {/* ═══════════════════════════════════════════════════════════════════
            TAB 3 — SCANNER
        ═══════════════════════════════════════════════════════════════════ */}
        {tab===3&&(
          <div className="up">
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:14}}>
              <div>
                <div style={{fontFamily:"Cinzel",fontSize:13,color:ACC,letterSpacing:3}}>MULTI-PAIR COSMIC SCANNER</div>
                <div style={{fontSize:9,color:MUT,marginTop:3}}>AI scans 8 pairs simultaneously — live news + cosmic alignment</div>
              </div>
              <Btn onClick={scan} disabled={scanning}>{scanning?"⟳ SCANNING ALL PAIRS...":"⬡ SCAN 8 PAIRS"}</Btn>
            </div>
            {scanResults.length>0&&(
              <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(270px,1fr))",gap:12}}>
                {scanResults.map((r,i)=>(
                  <Card key={i} style={{border:`1px solid ${sc(r.signal)}30`}}>
                    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}}>
                      <div style={{fontFamily:"Cinzel",fontSize:14,fontWeight:700,color:ACC}}>{r.pair}</div>
                      <div style={{fontFamily:"Cinzel",fontSize:14,fontWeight:900,color:sc(r.signal)}}>{r.signal}</div>
                    </div>
                    <div style={{display:"flex",justifyContent:"space-between",marginBottom:7,fontSize:10}}>
                      <span style={{color:MUT}}>~{r.price}</span>
                      <span style={{color:sc(r.trend),fontFamily:"Cinzel",fontSize:9}}>{r.trend}</span>
                    </div>
                    <div style={{height:3,background:BRD,borderRadius:2,marginBottom:8}}>
                      <div style={{height:"100%",width:`${r.confidence}%`,background:sc(r.signal),borderRadius:2}}/>
                    </div>
                    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}}>
                      <span style={{fontSize:9,color:MUT}}>Confidence: <span style={{color:r.confidence>=70?GRN:r.confidence>=50?GLD:RED,fontFamily:"Cinzel"}}>{r.confidence}%</span></span>
                      <Pill label={`✦ ${r.cosmic||r.cosmicAlignment}`} color={r.cosmic==="ALIGNED"||(r.cosmicAlignment==="ALIGNED")?GRN:r.cosmic==="MISALIGNED"||(r.cosmicAlignment==="MISALIGNED")?RED:GLD}/>
                    </div>
                    <div style={{fontSize:10,color:"#b4b0d0",lineHeight:1.5,borderTop:`1px solid ${BRD}`,paddingTop:8}}>{r.reason}</div>
                  </Card>
                ))}
              </div>
            )}
            {!scanResults.length&&!scanning&&(
              <div style={{textAlign:"center",padding:"60px 16px"}}>
                <div style={{fontSize:48,marginBottom:12}}>📡</div>
                <div style={{fontFamily:"Cinzel",fontSize:13,color:MUT}}>Scanner standing by — 8 pairs ready to analyze</div>
              </div>
            )}
          </div>
        )}

        {/* ═══════════════════════════════════════════════════════════════════
            TAB 4 — JOURNAL
        ═══════════════════════════════════════════════════════════════════ */}
        {tab===4&&(
          <div className="up">
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12}}>
              <div style={{fontFamily:"Cinzel",fontSize:13,color:ACC,letterSpacing:3}}>TRADE JOURNAL</div>
              <Btn onClick={()=>setShowAdd(!showAdd)}>{showAdd?"✕ CANCEL":"+ LOG TRADE"}</Btn>
            </div>

            {showAdd&&(
              <Card style={{border:`1px solid ${ACC}20`,marginBottom:14}}>
                <div style={{fontFamily:"Cinzel",fontSize:9,color:ACC,letterSpacing:2,marginBottom:14}}>NEW TRADE ENTRY</div>
                <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr 1fr",gap:10,marginBottom:10}}>
                  <div>
                    <div style={{fontSize:8,color:MUT,marginBottom:4,fontFamily:"Cinzel"}}>PAIR</div>
                    <select value={tradeForm.pair} onChange={e=>setTradeForm(p=>({...p,pair:e.target.value}))}
                      style={{background:BG,border:`1px solid ${BRD}`,color:ACC,padding:"7px 10px",borderRadius:6,fontFamily:"monospace",fontSize:11,width:"100%",cursor:"pointer"}}>
                      <option value="">Select...</option>
                      {PAIRS.map(p=><option key={p}>{p}</option>)}
                    </select>
                  </div>
                  <div>
                    <div style={{fontSize:8,color:MUT,marginBottom:4,fontFamily:"Cinzel"}}>DIRECTION</div>
                    <div style={{display:"flex",gap:5}}>
                      {["BUY","SELL"].map(d=>(
                        <button key={d} onClick={()=>setTradeForm(p=>({...p,direction:d}))}
                          style={{flex:1,background:tradeForm.direction===d?(d==="BUY"?"rgba(52,211,153,0.12)":"rgba(248,113,113,0.12)"):BG,border:`1px solid ${tradeForm.direction===d?(d==="BUY"?GRN:RED):BRD}`,color:tradeForm.direction===d?(d==="BUY"?GRN:RED):MUT,padding:"7px",borderRadius:6,fontFamily:"Cinzel",fontSize:9}}>
                          {d}
                        </button>
                      ))}
                    </div>
                  </div>
                  <Inp label="ENTRY PRICE" k="entry" ph="1.08500" state={tradeForm} setState={setTradeForm}/>
                  <Inp label="RESULT (pips)" k="result" ph="+50 or -30" state={tradeForm} setState={setTradeForm}/>
                </div>
                <div style={{marginBottom:10}}>
                  <div style={{fontSize:8,color:MUT,marginBottom:4,fontFamily:"Cinzel"}}>NOTES</div>
                  <textarea value={tradeForm.note} onChange={e=>setTradeForm(p=>({...p,note:e.target.value}))}
                    placeholder="What happened? Which cosmic factors? What did you learn?"
                    style={{background:BG,border:`1px solid ${BRD}`,borderRadius:6,padding:"8px 10px",fontSize:11,width:"100%",height:56,resize:"vertical",color:"#e2e0ff",fontFamily:"monospace"}}/>
                </div>
                <div style={{display:"flex",gap:10,alignItems:"center"}}>
                  <Btn onClick={()=>{
                    const t={...tradeForm,date:new Date().toISOString(),moon:moon.name,moonEmoji:moon.emoji,zodiac:zodiac.name,zodiacEmoji:zodiac.e,number:num.num,id:Date.now()};
                    saveJournal([t,...journal]);
                    setTradeForm({pair:"",direction:"BUY",entry:"",result:"",note:""});
                    setShowAdd(false);
                  }}>✦ SAVE TRADE</Btn>
                  <div style={{fontSize:9,color:MUT,fontFamily:"Cinzel"}}>Auto-tagged: {moon.emoji} {moon.name} · {zodiac.e} {zodiac.name} · №{num.num}</div>
                </div>
              </Card>
            )}

            {/* Stats */}
            <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:10,marginBottom:12}}>
              {[{l:"TOTAL",v:journal.length,c:ACC},{l:"WINS",v:wins,c:GRN},{l:"LOSSES",v:journal.length-wins,c:RED},{l:"WIN RATE",v:journal.length>0?wr+"%":"—",c:GLD}].map(s=>(
                <Card key={s.l} style={{textAlign:"center",padding:"12px"}}>
                  <div style={{fontSize:8,color:MUT,fontFamily:"Cinzel",letterSpacing:1}}>{s.l}</div>
                  <div style={{fontFamily:"Cinzel",fontSize:22,fontWeight:700,color:s.c,marginTop:4}}>{s.v}</div>
                </Card>
              ))}
            </div>

            {journal.length===0?(
              <div style={{textAlign:"center",padding:"50px 16px",color:MUT,fontFamily:"Cinzel",fontSize:12}}>No trades yet. The more you log, the smarter COSMO gets.</div>
            ):(
              <div style={{display:"flex",flexDirection:"column",gap:8}}>
                {journal.map(t=>{
                  const res=parseFloat(t.result||0);
                  return(
                    <Card key={t.id} style={{border:`1px solid ${res>0?GRN:res<0?RED:BRD}18`,padding:"12px 16px"}}>
                      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:5}}>
                        <div style={{display:"flex",gap:7,alignItems:"center"}}>
                          <span style={{fontFamily:"Cinzel",fontSize:12,color:ACC,fontWeight:700}}>{t.pair}</span>
                          <Pill label={t.direction} color={t.direction==="BUY"?GRN:RED}/>
                          {t.entry&&<span style={{fontSize:9,color:MUT}}>@ {t.entry}</span>}
                        </div>
                        <div style={{display:"flex",gap:7,alignItems:"center"}}>
                          <span style={{fontSize:9,color:MUT}}>{t.moonEmoji} {t.zodiacEmoji} №{t.number}</span>
                          {t.result&&<span style={{fontFamily:"Cinzel",fontSize:12,color:res>0?GRN:RED,fontWeight:700}}>{res>0?"+":""}{t.result} pips</span>}
                        </div>
                      </div>
                      {t.note&&<div style={{fontSize:10,color:"#b4b0d0",lineHeight:1.5,marginBottom:3}}>{t.note}</div>}
                      <div style={{fontSize:8,color:MUT}}>{new Date(t.date).toLocaleString()}</div>
                    </Card>
                  );
                })}
              </div>
            )}
          </div>
        )}

        {/* ═══════════════════════════════════════════════════════════════════
            TAB 5 — CALCULATOR
        ═══════════════════════════════════════════════════════════════════ */}
        {tab===5&&(
          <div className="up" style={{maxWidth:660,margin:"0 auto"}}>
            <Card>
              <div style={{fontFamily:"Cinzel",fontSize:12,color:ACC,letterSpacing:3,marginBottom:18}}>✦ POSITION SIZE CALCULATOR</div>
              <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12,marginBottom:16}}>
                <Inp label="ACCOUNT BALANCE ($)" k="balance" ph="10000" state={calcForm} setState={setCalcForm}/>
                <Inp label="RISK % PER TRADE" k="risk" ph="1" state={calcForm} setState={setCalcForm}/>
                <Inp label="ENTRY PRICE" k="entry" ph="1.08500" state={calcForm} setState={setCalcForm}/>
                <Inp label="STOP LOSS PRICE" k="sl" ph="1.08200" state={calcForm} setState={setCalcForm}/>
                <Inp label="TAKE PROFIT PRICE" k="tp" ph="1.09200" state={calcForm} setState={setCalcForm}/>
              </div>
              {pos&&(
                <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(120px,1fr))",gap:10,marginBottom:16}}>
                  {[{l:"RISK AMOUNT",v:"$"+pos.riskAmt,c:RED},{l:"SL DISTANCE",v:pos.slDist,c:GLD},{l:"LOT SIZE",v:pos.lots,c:GRN},{l:"R:R RATIO",v:"1:"+pos.rr,c:ACC},{l:"POTENTIAL PROFIT",v:"$"+pos.potentialProfit,c:"#6ee7b7"}].map(s=>(
                    <div key={s.l} style={{background:BG,border:`1px solid ${BRD}`,borderRadius:8,padding:"11px",textAlign:"center"}}>
                      <div style={{fontSize:8,color:MUT,fontFamily:"Cinzel",letterSpacing:1}}>{s.l}</div>
                      <div style={{fontFamily:"Cinzel",fontSize:16,fontWeight:700,color:s.c,marginTop:5}}>{s.v}</div>
                    </div>
                  ))}
                </div>
              )}
              <div style={{background:"rgba(177,151,252,0.04)",border:`1px solid ${ACC}15`,borderRadius:9,padding:14}}>
                <div style={{fontFamily:"Cinzel",fontSize:9,color:ACC,letterSpacing:2,marginBottom:9}}>✦ COSMO RISK GUIDANCE TODAY</div>
                <div style={{fontSize:11,color:"#c4c0e0",lineHeight:1.6,marginBottom:7}}>{moon.advice}</div>
                <div style={{fontSize:11,color:num.color,lineHeight:1.6,marginBottom:10}}>Number {num.num} Day: {num.market}</div>
                <div style={{padding:"8px 12px",background:cosmicScore>=70?"rgba(52,211,153,0.07)":"rgba(248,113,113,0.07)",borderRadius:6,fontSize:11,color:cosmicScore>=70?GRN:RED,fontFamily:"Cinzel"}}>
                  Cosmic Score {cosmicScore}% — {cosmicScore>=70?"Good today. Use normal position size.":cosmicScore>=50?"Moderate. Consider 0.5× size.":"⚠️ Poor alignment. 0.25× size or skip."}
                </div>
              </div>
            </Card>
          </div>
        )}

      </main>
    </div>
  );
}
