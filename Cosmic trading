function getNumerology() {
  const d=new Date();
  let n=(d.getDate()+d.getMonth()+1+(d.getFullYear()%100));
  while(n>9)n=String(n).split("").reduce((a,b)=>a+parseInt(b),0);
  const map={
    1:{name:"New Beginnings",energy:"INITIATION",market:"Strong opening moves. Breakouts favored today.",color:"#f87171",fav:true},
    2:{name:"Balance",energy:"HARMONY",market:"Forex pairs excellent. Balanced energy today.",color:"#a78bfa",fav:true},
    3:{name:"Expansion",energy:"GROWTH",market:"Markets surprise to upside. Expansion energy.",color:"#34d399",fav:true},
    4:{name:"Structure",energy:"STABILITY",market:"Consolidation day. Respect structure. Range trade.",color:"#60a5fa",fav:false},
    5:{name:"Change",energy:"VOLATILITY",market:"High volatility. Major reversals possible. Caution.",color:"#fbbf24",fav:false},
