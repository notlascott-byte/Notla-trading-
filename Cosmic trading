function getMercuryRx(){
  const d=new Date();
  const doy=Math.floor((d-new Date(d.getFullYear(),0,0))/864e5);
  return[[15,35],[95,115],[175,195],[255,275],[335,355]].some(([s,e])=>doy>=s&&doy<=e);
}

function getSession(){
  const h=new Date().getUTCHours();
  if(h>=13&&h<17)return{name:"London/NY Overlap",vol:"EXTREME",color:"#f87171",best:"EUR/USD, GBP/USD, XAU/USD"};
  if(h>=8&&h<13) return{name:"London Open",vol:"HIGH",color:"#60a5fa",best:"EUR/USD, GBP/USD, EUR/GBP"};
  if(h>=17&&h<22)return{name:"New York",vol:"HIGH",color:"#34d399",best:"USD/CAD, EUR/USD, US30"};
  if(h>=0&&h<9)  return{name:"Tokyo",vol:"MEDIUM",color:"#fbbf24",best:"USD/JPY, AUD/JPY, EUR/JPY"};
  return{name:"Sydney/Off-Hours",vol:"LOW",color:"#818cf8",best:"AUD/USD, NZD/USD"};
}

function getCosmicScore(moon,zodiac,num,mercuryRx,session){
  let s=50;
  if(moon.ill>20&&moon.ill<80)s+=12;
  if(moon.ill>=80)s-=12;
  if(zodiac.bull)s+=10;
  if(mercuryRx)s-=20;
  if(num.fav)s+=10;
  if(session.vol==="EXTREME"||session.vol==="HIGH")s+=8;
  return Math.min(96,Math.max(15,s));
}

