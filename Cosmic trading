function getMoonPhase() {
  const now = new Date();
  const known = new Date("2000-01-06T18:14:00Z");
  const cycle = 29.530588853;
  const diff = (now - known) / (1000 * 60 * 60 * 24);
  const phase = ((diff % cycle) + cycle) % cycle;
  const pct = (phase / cycle) * 100;
  if (pct < 3)   return { name:"New Moon",       emoji:"🌑", energy:"NEW BEGINNINGS", bias:"Volatile. Avoid new entries.",      advice:"Wait for direction. New cycle beginning.",  color:"#818cf8", ill:0,   favorable:false };
  if (pct < 25)  return { name:"Waxing Crescent", emoji:"🌒", energy:"GROWTH",        bias:"Bullish momentum building.",         advice:"Favor BUY setups. Moon energy rising.",     color:"#a78bfa", ill:25,  favorable:true  };
  if (pct < 27)  return { name:"First Quarter",   emoji:"🌓", energy:"ACTION",        bias:"Breakouts forming.",                 advice:"Watch for breakouts. High energy.",         color:"#c084fc", ill:50,  favorable:true  };
  if (pct < 50)  return { name:"Waxing Gibbous",  emoji:"🌔", energy:"PEAK BUILD",   bias:"Strong bullish pressure.",           advice:"Best for BUY trades. Energy peaking.",      color:"#e879f9", ill:75,  favorable:true  };
  if (pct < 53)  return { name:"Full Moon",       emoji:"🌕", energy:"PEAK POWER",   bias:"EXTREME volatility. Major reversals.",advice:"Tight SL only. Reversals very likely.",    color:"#fef08a", ill:100, favorable:false };
  if (pct < 75)  return { name:"Waning Gibbous",  emoji:"🌖", energy:"RELEASING",    bias:"Bearish pressure building.",         advice:"Favor SELL setups. Energy falling.",        color:"#fbbf24", ill:65,  favorable:true  };
  if (pct < 78)  return { name:"Last Quarter",    emoji:"🌗", energy:"REFLECTION",   bias:"Consolidation. Reversal zone.",      advice:"Close trades. Reflect. Wait.",             color:"#f97316", ill:50,  favorable:false };
